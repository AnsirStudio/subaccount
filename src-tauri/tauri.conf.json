{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SubAccount",
  "version": "0.2.0",
  "identifier": "com.local.subaccount",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SubAccount",
        "width": 900,
        "height": 980,
        "minWidth": 900,
        "minHeight": 720,
        "maxWidth": 900,
        "maxHeight": 1100,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 24
        },
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
